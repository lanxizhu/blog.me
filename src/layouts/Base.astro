---
import { BaseHead, Footer, Header } from '@/components'
import ArtDots from '@/components/ArtDots.astro'
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts'
import 'virtual:uno.css'

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />

    <script is:inline>
      const theme = localStorage.getItem('blog-theme')

      if (theme === 'dark') {
        document.documentElement.classList.add('dark')
      }
    </script>

    <script>
      const main = document.querySelector('main')

      function hasOnlyText(a: HTMLAnchorElement) {
        if (!(a instanceof HTMLAnchorElement)) return false
        if (a.children.length > 0) return false
        return a.textContent.trim().length > 0
      }

      if (main instanceof HTMLElement) {
        const links = main.querySelectorAll('a')

        links.forEach((link) => {
          if (!hasOnlyText(link)) return

          const text = link.dataset.text || link.textContent.trim()
          link.ariaLabel = link.textContent.trim() || link.getAttribute('href') || 'Link'
          link.dataset.text = link.ariaLabel
          link.classList.add('roll-link')

          const gap = 35
          const anims: Animation[] = []

          link.textContent = ''
          ;[...text].forEach((ch, i) => {
            const wrap = document.createElement('span')
            wrap.className = 'char-wrap'
            wrap.style.setProperty('--i', String(i))
            if (ch === ' ') {
              wrap.textContent = '\u00A0'
              link.append(wrap)
              return
            }

            const cur = document.createElement('span')
            cur.className = 'char'
            cur.textContent = ch

            const next = document.createElement('span')
            next.className = 'char-next'
            next.textContent = ch

            wrap.append(cur, next)
            link.append(wrap)

            const timing = {
              duration: 420,
              delay: i * gap,
              // endDelay: i * gap,
              endDelay: (text.length - 1 - i) * gap * 0.5,
              easing: 'cubic-bezier(.22,1,.36,1)',
            }

            const a1 = cur.animate([{ transform: 'translateY(0%)' }, { transform: 'translateY(-100%)' }], timing)

            const a2 = next.animate([{ transform: 'translateY(0%)' }, { transform: 'translateY(-100%)' }], timing)

            a1.pause()
            a1.currentTime = 0
            a2.pause()
            a2.currentTime = 0

            anims.push(a1, a2)
          })

          link.addEventListener('pointerenter', () => {
            anims.forEach((a) => {
              a.playbackRate = 1
              a.play()
            })
          })

          link.addEventListener('pointerleave', () => {
            anims.forEach((a) => {
              a.playbackRate = 1
              a.reverse()
            })
          })
        })

        document.addEventListener('copy', (e) => {
          const sel = window.getSelection()
          if (!sel || sel.rangeCount === 0 || sel.isCollapsed) return

          const range = sel.getRangeAt(0)
          const root
            = range.commonAncestorContainer.nodeType === Node.ELEMENT_NODE
              ? (range.commonAncestorContainer as Element)
              : (range.commonAncestorContainer.parentElement as Element)

          // handle copy only when the selection is within a paragraph, to avoid interfering with copying code blocks or other non-text content
          const inP = root && (root.closest('p') || root.querySelector('p'))
          if (!inP) return

          // clone the selected content so we can modify it without affecting the actual page
          const frag = range.cloneContents()

          // replace any links that have the roll-link class with their text content, to avoid copying the animated spans
          frag.querySelectorAll?.('a.roll-link').forEach((a) => {
            const text = (a.getAttribute('data-text') || a.textContent || '').trim()
            a.replaceWith(document.createTextNode(text))
          })

          // extract plain text and clean up extra whitespace
          const div = document.createElement('div')
          div.appendChild(frag)
          const text = div.textContent?.replace(/\s+/g, ' ').trim() || ''

          if (!text) return
          e.preventDefault()
          e.clipboardData?.setData('text/plain', text)
        })
      }
    </script>

    <slot name="style" />
  </head>
  <body>
    <Header />
    <main transition:animate="slide">
      <slot />
    </main>
    <Footer />

    <ArtDots />
  </body>
</html>
